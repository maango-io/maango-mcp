# Local development — copy to .env and fill in.
# For the hosted mcp.maango.io deployment, these are set as platform env vars.

# Optional. Raises API rate limits. Leave blank for anonymous (lower rate limit).
MAANGO_API_KEY=

# Maango REST API base URL. Default is fine for production.
MAANGO_API_BASE_URL=https://api.maango.io

# Transport: stdio (local Claude Desktop), sse (remote), streamable-http (remote, modern).
MAANGO_MCP_TRANSPORT=stdio

# Hosted mode only — bind address for sse / streamable-http.
MAANGO_MCP_HOST=0.0.0.0
MAANGO_MCP_PORT=8000
